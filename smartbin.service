[Unit]
Description=Smartbin IoT Auto-Detection Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=eka
WorkingDirectory=/home/eka/smartbin-iot
# Ganti /home/pi/ dengan username Raspberry Pi Anda jika berbeda
# Jika menggunakan Virtual Environment (venv), ubah path python di bawah ini
ExecStart=/usr/bin/python3 /home/eka/smartbin-iot/smartbin_iot.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
